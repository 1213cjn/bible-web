.container{
  width:100vw;
  height:100vh;

  }
  .page{
    width:100vw;
    height:100vh;
    position:relative;
  }
  .start{
  height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  }
  
  .btn{
    width: 300rpx;
    height: 80rpx;
    background-color: #F39C12;  /* 柯基橘色 */
    color: white;
    font-size: 32rpx;
    border-radius: 40rpx;        /* 圆角让它更可爱 */
    box-shadow: 0 4rpx 8rpx rgba(0,0,0,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    outline: none;
  }
  
  .progress-tip {
    position: absolute;
    top: 100rpx;
    left: 50%;
    transform: translateX(-50%);
    background-color: rgba(0, 0, 0, 0.7);
    color: #fff;
    padding: 20rpx 40rpx;
    border-radius: 40rpx;
    font-size: 28rpx;
    z-index: 100;
    max-width: 80%;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .arPage{
    display: block;
    width: 100%;
    height:70%;
  }
  .bg{
    position:absolute;
    width:100%;
    height:100%;
    left:0;
    top:0;
    z-index:-1;
  }